            "row": 2
          }
        },
        {
          "name": "tbl_patients",
          "type": "datagrid",
          "layout": {
            "col": 5,
            "colSpan": 8,
            "row": 1,
            "rowSpan": 2
          },
          "metadata": {
            "keyField": "PATIENT_ID",
            "searchPanel": false,
            "filterEnabled": true,
            "dataSource": {
              "type": "query",
              "tableName": "APPS.DEMO_PATIENTS",
              "keyField": "PATIENT_ID",
              "bindVariables": [
                {
                  "name": "p_search_name",
                  "sourceField": "f_search_name"
                },
                {
                  "name": "p_search_phone",
                  "sourceField": "f_search_phone"
                }
              ],
              "query": "SELECT * FROM APPS.DEMO_PATIENTS WHERE (:p_search_name IS NULL OR LOWER(FIRST_NAME || ' ' || LAST_NAME) LIKE LOWER('%'||:p_search_name||'%')) AND (:p_search_phone IS NULL OR CONTACT_NUMBER LIKE '%'||:p_search_phone||'%')"
            },
            "columns": [
              { "key": "PATIENT_ID", "dataType": "string", "label": "COL_PATIENT_ID", "visible": true },
              { "key": "FIRST_NAME", "dataType": "string", "label": "COL_FIRST_NAME", "visible": true },
              { "key": "LAST_NAME", "dataType": "string", "label": "COL_LAST_NAME", "visible": true },
              { "key": "GENDER", "dataType": "string", "label": "COL_GENDER", "visible": true },
              { "key": "DATE_OF_BIRTH", "dataType": "date", "label": "COL_DATE_OF_BIRTH", "visible": true, "format": "dd/MM/yyyy" },
              { "key": "CONTACT_NUMBER", "dataType": "string", "label": "COL_CONTACT_NUMBER", "visible": true },
              { "key": "ADDRESS", "dataType": "string", "label": "COL_ADDRESS", "visible": true },
              { "key": "REGISTRATION_DATE", "dataType": "date", "label": "COL_REGISTRATION_DATE", "visible": true, "format": "dd/MM/yyyy" },
              { "key": "INSURANCE_PROVIDER", "dataType": "string", "label": "COL_INSURANCE_PROVIDER", "visible": true },
              { "key": "INSURANCE_NUMBER", "dataType": "string", "label": "COL_INSURANCE_NUMBER", "visible": true },
              { "key": "EMAIL", "dataType": "string", "label": "COL_EMAIL", "visible": true }
            ]
          }
        }
      ]
    }
