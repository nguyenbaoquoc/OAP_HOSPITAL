          },
          "metadata": {
            "keyField": "PATIENT_CODE",
            "title": "tbl_patients",
            "pageType": "table",
            "dataSource": {
              "type": "query",
              "tableName": "DEMO_PATIENTS",
              "keyField": "PATIENT_CODE",
              "insertQuery": "INSERT INTO DEMO_PATIENTS (PATIENT_ID, FIRST_NAME, LAST_NAME, GENDER, DATE_OF_BIRTH, CONTACT_NUMBER, ADDRESS, REGISTRATION_DATE, INSURANCE_PROVIDER, INSURANCE_NUMBER, EMAIL) VALUES (:PATIENT_CODE, :FIRST_NAME, :LAST_NAME, :GENDER, :DATE_OF_BIRTH, :CONTACT_NUMBER, :ADDRESS, :REGISTRATION_DATE, :INSURANCE_PROVIDER, :INSURANCE_NUMBER, :EMAIL)",
              "updateQuery": "UPDATE DEMO_PATIENTS SET FIRST_NAME = :FIRST_NAME, LAST_NAME = :LAST_NAME, GENDER = :GENDER, DATE_OF_BIRTH = :DATE_OF_BIRTH, CONTACT_NUMBER = :CONTACT_NUMBER, ADDRESS = :ADDRESS, REGISTRATION_DATE = :REGISTRATION_DATE, INSURANCE_PROVIDER = :INSURANCE_PROVIDER, INSURANCE_NUMBER = :INSURANCE_NUMBER, EMAIL = :EMAIL WHERE PATIENT_ID = :PATIENT_CODE",
              "deleteQuery": "DELETE FROM DEMO_PATIENTS WHERE PATIENT_ID = :PATIENT_CODE",
              "bindVariables": [
                {
                  "name": "p_search_name",
                  "sourceField": "f_search_name"
                },
                {
                  "name": "p_search_phone",
                  "sourceField": "f_search_phone"
                },
                {
                  "name": "p_gender",
                  "sourceField": "f_gender"
                }
              ],
              "query": "SELECT PATIENT_ID AS PATIENT_CODE, FIRST_NAME, LAST_NAME, GENDER, DATE_OF_BIRTH, CONTACT_NUMBER, ADDRESS, REGISTRATION_DATE, INSURANCE_PROVIDER, INSURANCE_NUMBER, EMAIL FROM DEMO_PATIENTS WHERE (:p_search_name IS NULL OR LOWER(FIRST_NAME || ' ' || LAST_NAME) LIKE LOWER('%'||:p_search_name||'%')) AND (:p_search_phone IS NULL OR CONTACT_NUMBER LIKE '%'||:p_search_phone||'%') AND (:p_gender IS NULL OR GENDER = :p_gender) ORDER BY PATIENT_ID"
            },
