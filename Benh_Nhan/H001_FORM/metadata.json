{
  "pageType": "form",
  "pageCode": "H001_FORM",
  "metadataVersion": 2,
  "title": "Biểu mẫu Bệnh nhân",
  "dataSource": {
    "type": "query",
    "tableName": "DEMO_PATIENTS",
    "keyField": "PATIENT_ID",
    "query": "SELECT PATIENT_ID, FIRST_NAME, LAST_NAME, GENDER, DATE_OF_BIRTH, CONTACT_NUMBER, ADDRESS, REGISTRATION_DATE, INSURANCE_PROVIDER, INSURANCE_NUMBER, EMAIL FROM DEMO_PATIENTS WHERE PATIENT_ID = :id",
    "saveQuery": "DECLARE v_patient_id VARCHAR2(20) := :PATIENT_ID; v_first_name VARCHAR2(20) := :FIRST_NAME; v_last_name VARCHAR2(20) := :LAST_NAME; v_gender VARCHAR2(20) := :GENDER; v_dob DATE := :DATE_OF_BIRTH; v_contact VARCHAR2(50) := :CONTACT_NUMBER; v_address VARCHAR2(20) := :ADDRESS; v_reg_date DATE := :REGISTRATION_DATE; v_ins_prov VARCHAR2(20) := :INSURANCE_PROVIDER; v_ins_num VARCHAR2(20) := :INSURANCE_NUMBER; v_email VARCHAR2(4000) := :EMAIL; BEGIN IF :id IS NULL THEN INSERT INTO DEMO_PATIENTS (PATIENT_ID, FIRST_NAME, LAST_NAME, GENDER, DATE_OF_BIRTH, CONTACT_NUMBER, ADDRESS, REGISTRATION_DATE, INSURANCE_PROVIDER, INSURANCE_NUMBER, EMAIL) VALUES (v_patient_id, v_first_name, v_last_name, v_gender, v_dob, v_contact, v_address, v_reg_date, v_ins_prov, v_ins_num, v_email); ELSE UPDATE DEMO_PATIENTS SET FIRST_NAME = v_first_name, LAST_NAME = v_last_name, GENDER = v_gender, DATE_OF_BIRTH = v_dob, CONTACT_NUMBER = v_contact, ADDRESS = v_address, REGISTRATION_DATE = v_reg_date, INSURANCE_PROVIDER = v_ins_prov, INSURANCE_NUMBER = v_ins_num, EMAIL = v_email WHERE PATIENT_ID = v_patient_id; END IF; COMMIT; END;"
  },
